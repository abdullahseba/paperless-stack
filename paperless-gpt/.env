PAPERLESS_BASE_URL=http://paperless:8000
# change to your paperless API token
PAPERLESS_API_TOKEN=3d4f85d60213e655242a9a8b4097184fb11668fe
# Optional
# PAPERLESS_PUBLIC_URL=http://paperless.mydomain.com

LLM_PROVIDER=ollama
LLM_MODEL=gpt-oss:20b
OLLAMA_HOST=http://192.168.0.58:11434
# Sets Ollama NumCtx (context window)
OLLAMA_CONTEXT_LENGTH=8192
# Recommended for smaller models
TOKEN_LIMIT=1000

# Optional, default: English
LLM_LANGUAGE=English

# Default OCR provider
OCR_PROVIDER=llm
# openai, ollama, mistral, or anthropic
VISION_LLM_PROVIDER=ollama
# minicpm-v (ollama) or gpt-4o (openai) or claude-sonnet-4-5 (anthropic/claude)
VISION_LLM_MODEL=minicpm-v:8b

AUTO_OCR_TAG=paperless-gpt-ocr-auto
AUTO_TAG=paperless-gpt-auto
MANUAL_TAG=paperless-gpt-manual
PDF_OCR_TAGGING=true
PDF_OCR_COMPLETE_TAG=paperless-gpt-ocr-complete
PDF_UPLOAD=false

LOG_LEVEL=DEBUG

# For a full list of configuration options, see the documentation at: https://github.com/icereed/paperless-gpt?tab=readme-ov-file#docker-compose